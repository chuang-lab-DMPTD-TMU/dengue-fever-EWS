# ============================================================
# Snakemake Workflow — Dengue ML Pipeline (per-region, multi-arch)
# ============================================================
# Usage:
#   # Run full pipeline (tune → train → evaluate → aggregate):
#   snakemake --cores 8 --resources gpu=1
#
#   # Also run SHAP/XAI after the main pipeline:
#   snakemake all_xai --cores 8 --resources gpu=1
#
#   # Use a different config:
#   snakemake --cores 8 --configfile config/my_config.yaml
#
# Pipeline per (study, region) — defined in rules/xgboost.smk / rules/RF.smk:
#   [checkpoint] discover_regions
#       → tune  →  train  →  evaluate  →  aggregate_results
#
#   STGAT pipeline — defined in rules/stgat.smk:
#       tune_stgat  →  train_stgat  →  eval_stgat
#
#   XAI (opt-in via `snakemake all_xai`) — defined in rules/XAI.smk:
#       train + evaluate → shap_analysis
#
# Adding a new run:
#   Add an entry to config["runs"] with at minimum:
#     arch, version
#   XGBoost runs also use: validation, landuse
#   Optional per-run overrides: data, hyperparams
# ============================================================

configfile: "config/config.yaml"

include: "rules/xgboost.smk"
include: "rules/RF.smk"
include: "rules/stgat.smk"
include: "rules/XAI.smk"
include: "rules/IG.smk"


# ---------------------------------------------------------------------------
# Shared helpers — used by input functions across included rule files
# ---------------------------------------------------------------------------

def _landuse_suffix(run):
    return "lulc" if run.get("landuse") == "t" else ""

def _validation_strategy(run):
    return "kfold" if run.get("validation") == "k" else "walk"

def _study_name(run):
    """
    Unique identifier for a run, used as the {study} wildcard throughout.
    Format: {arch}-{validation}-{landuse_suffix}-{version}
    Parts that are empty (e.g. no landuse suffix) are dropped.
    """
    arch = run.get("arch", "xgbC")
    parts = [arch, _validation_strategy(run), _landuse_suffix(run), run["version"]]
    return "-".join(p for p in parts if p)

def _run_for_study(study_str):
    """Reverse-lookup: study string → run config dict."""
    return next(r for r in config["runs"] if _study_name(r) == study_str)

def _all_studies():
    return [_study_name(r) for r in config["runs"]]

def _all_experiments():
    """Return distinct experiment names across all runs that have the field set."""
    return list({r["experiment"] for r in config["runs"] if "experiment" in r})

def _studies_for_experiment(experiment_name):
    """All study names that belong to a given experiment."""
    return [
        _study_name(r) for r in config["runs"]
        if r.get("experiment") == experiment_name
    ]

def _regions_for_study(wc):
    """Read the checkpoint output and return the list of region strings."""
    regions_file = checkpoints.discover_regions.get(study=wc.study).output.region_list
    with open(regions_file) as fh:
        return [line.strip() for line in fh if line.strip()]


# ---------------------------------------------------------------------------
# rule all — core pipeline targets (no XAI)
# Run `snakemake all_xai` to also produce SHAP outputs.
# ---------------------------------------------------------------------------

rule all:
    default_target: True
    input:
        expand(
            "reports/tables/{study}_national_results.csv",
            study = _all_studies()
        ),
        expand(
            "reports/tables/{experiment}_comparison.csv",
            experiment = _all_experiments()
        )


# ---------------------------------------------------------------------------
# rule all_xai — opt-in target that also runs SHAP for every study/region
# ---------------------------------------------------------------------------

def _all_shap_flags(wildcards):
    """Input function so Snakemake waits for the checkpoint before expanding."""
    flags = []
    for study in _all_studies():
        wc = type("W", (), {"study": study})()
        for region in _regions_for_study(wc):
            flags.append(f".snakemake/flags/{study}/{region}_shap.done")
    return flags


rule all_xai:
    input:
        expand(
            "reports/tables/{study}_national_results.csv",
            study = _all_studies()
        ),
        expand(
            "reports/tables/{experiment}_comparison.csv",
            experiment = _all_experiments()
        ),
        _all_shap_flags
